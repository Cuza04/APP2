APP_NAME="Control Inspecciones"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Terminal Moin (Costa Rica). En producción: APP_ENV=production, APP_DEBUG=false
APP_TIMEZONE=America/Costa_Rica

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Desarrollo local (SQLite) ---
DB_CONNECTION=sqlite

# --- Producción (descomentar y usar MySQL o PostgreSQL) ---
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://monitoreo.terminal.local
# LOG_LEVEL=info
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=app2
# DB_USERNAME=
# DB_PASSWORD=

# Turnos largos en el PC del puesto de monitoreo (minutos)
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Activar en producción con HTTPS:
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Informe CSV diario (23:55). Se guarda en storage/app/reports

# Longitud mínima de contraseña para usuarios del panel
PASSWORD_MIN_LENGTH=8

# Horario operativo del terminal (24 h). Solo estas franjas cuentan para cumplimiento.
# Ejemplo turno diurno: INSPECTION_OPERATING_START_HOUR=6 y INSPECTION_OPERATING_END_HOUR=22
INSPECTION_OPERATING_START_HOUR=0
INSPECTION_OPERATING_END_HOUR=24

# Recordatorios de random (minutos dentro de cada hora)
INSPECTION_REMINDER_WARNING_MINUTE=15
INSPECTION_REMINDER_URGENT_MINUTE=30

# Retención de notificaciones del panel (días)
INSPECTION_NOTIFICATION_RETENTION_DAYS=30

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
